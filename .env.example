# Variables utilisées par docker-compose (copier vers .env à la racine).

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=incident_entry

# Fournisseur d'identité Alfresco ACS
ALFRESCO_BASE_URL=https://alfresco.company.com

# Sessions — clé AES-256 (32 octets). Générer avec : openssl rand -hex 32
SESSION_ENCRYPTION_KEY=

# Cookie de session
SESSION_COOKIE_NAME=app_session
SESSION_DURATION_HOURS=8
# false = Docker HTTP local ; true = production HTTPS
SESSION_COOKIE_SECURE=false

# URL publique d'accès à l'application (via Nginx, port 80 par défaut).
# Exemple réseau local : http://192.168.1.26
PUBLIC_APP_URL=http://localhost

# CORS : doit correspondre exactement à l'origine du navigateur.
# Avec Nginx sur le port 80 : http://<ip-serveur> (sans port si 80).
CORS_ORIGIN=http://localhost

# Port HTTP exposé par Nginx
NGINX_HTTP_PORT=80

# Niveau de log backend
LOG_LEVEL=info
