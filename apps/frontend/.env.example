# URL interne du backend pour les rewrites Next.js (proxy /api côté serveur).
# En développement, le navigateur appelle localhost:3000/api/* (même origine).
BACKEND_URL=http://localhost:3001

# Optionnel : utilisé uniquement en SSR si BACKEND_URL n'est pas défini.
NEXT_PUBLIC_API_URL=http://localhost:3001
